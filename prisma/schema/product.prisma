model Product {
   id            String   @id @default(uuid())
   name          String
   picture       String?
   description   String?
   note          String?
   price         Float
   dynamicFields Json?
   category      String?
   brand         String?
   sku           String?  @unique
   stock         Int      @default(0)
   isActive      Boolean  @default(true)
   createdAt     DateTime @default(now())
   updatedAt     DateTime @updatedAt
   review        Review[]

   @@map("products")
}
