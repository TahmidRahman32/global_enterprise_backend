{
   "compilerOptions": {
      "target": "ES2020",
      "module": "CommonJS",
      "moduleResolution": "node",
      "ignoreDeprecations": "6.0",
      "rootDir": "./src",
      "outDir": "./dist",
      "strict": false,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "resolveJsonModule": true,
      "types": ["node", "express", "multer"],
      "sourceMap": true
   },
   "include": ["src"],
   "exclude": ["node_modules", "dist"]
}
