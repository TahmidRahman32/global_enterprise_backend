// 

{
   "compilerOptions": {
      "rootDir": "./src",
      "outDir": "./dist",
      "types": ["node", "express", "multer"],
      "sourceMap": true,
      "declaration": true,
      "declarationMap": true,
      "noUncheckedIndexedAccess": true,
      "jsx": "react-jsx",
      "isolatedModules": true,
      "noUncheckedSideEffectImports": true,
      "moduleDetection": "force",
      "skipLibCheck": true,
      "module": "ESNext",
      "moduleResolution": "bundler",
      "target": "ES2023",
      "strict": false,
      "noImplicitAny": false,
      "esModuleInterop": true
   },
   "exclude": ["node_modules", "dist", "prisma.config.ts"]
}